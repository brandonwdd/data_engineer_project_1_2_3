# Project 2: Metrics Service + Reverse ETL
# Environment variable example
# Copy to .env and adjust for your environment

# ============================================
# Trino (Metrics API and dbt)
# ============================================
TRINO_HOST=localhost
TRINO_PORT=8080
TRINO_USER=admin
TRINO_PASSWORD=
TRINO_CATALOG=iceberg
TRINO_SCHEMA=mart_mart

# ============================================
# Metrics API
# ============================================
# API port
API_PORT=8000
API_HOST=0.0.0.0

# Query timeout (seconds)
QUERY_TIMEOUT_SECONDS=30

# Cache TTL (seconds)
CACHE_TTL_SECONDS=300

# ============================================
# Postgres (Reverse ETL)
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=project1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Reverse ETL target table
SEGMENT_TABLE=customer_segments

# ============================================
# Kafka (Reverse ETL)
# ============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SEGMENT_TOPIC=segment_updates

# ============================================
# dbt
# ============================================
# dbt project dir (relative to project root)
DBT_PROJECT_DIR=analytics/dbt

# ============================================
# Airflow (optional)
# ============================================
AIRFLOW_HOST=localhost
AIRFLOW_PORT=8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin

# ============================================
# Environment
# ============================================
ENVIRONMENT=dev
# Options: dev, stg, prod

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
