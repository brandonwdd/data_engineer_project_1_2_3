  COALESCE(total_amount, 0) AS total_amount,
  updated_at,
  _bronze_event_uid,
  _bronze_ordering_key,
  _bronze_ts_ms,
  _silver_updated_at
FROM "iceberg"."mart_stg"."stg_orders"
WHERE total_amount >= 0  -- Business rule: amount must be non-negative
    )
